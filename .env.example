# Database — sqlite for local dev; postgres for compose / prod
DATABASE_URL=sqlite:///./kyc.db
# DATABASE_URL=postgresql+psycopg2://kyc:kyc-dev-password@localhost:5432/kyc

# JWT auth — KYC_AUTH_* are read by AuthSettings via pydantic-settings
KYC_AUTH_SECRET=dev-secret-change-me
KYC_AUTH_ALGORITHM=HS256
KYC_AUTH_ACCESS_TOKEN_TTL_MINUTES=60

# Uvicorn workers (only used inside the container entrypoint)
WORKERS=2
